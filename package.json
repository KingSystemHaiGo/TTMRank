{
  "name": "ttmrank-web",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:analysis": "node scripts/build-analysis.mjs",
    "build:apps": "node scripts/build-page-bundles.mjs",
    "build:site": "npm run build:apps && node scripts/build-site.mjs",
    "build:visual": "node scripts/build-visual.mjs",
    "check:analysis-bundle": "node scripts/check-page-bundles.mjs",
    "check:visual-budget": "node scripts/check-visual-budget.mjs",
    "test:unit": "node --test tests/web/*.test.js tests/worker/*.test.js",
    "test:site": "node --test tests/site/*.test.js",
    "test:e2e": "playwright test",
    "test:performance": "playwright test --config playwright.performance.config.js",
    "test": "npm run build:site && npm run test:unit && npm run test:site && npm run test:e2e && npm run test:performance"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "esbuild": "0.28.1",
    "pixi.js": "8.19.0",
    "three": "0.185.1"
  }
}
