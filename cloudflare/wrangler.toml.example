name = "ttmrank-analytics"
main = "analytics-worker.js"
compatibility_date = "2026-07-01"

[[d1_databases]]
binding = "DB"
database_name = "ttmrank-history"
database_id = "replace-with-database-id"

[vars]
ALLOWED_ORIGINS = "https://kingsystemhaigo.github.io,http://127.0.0.1:4173,http://127.0.0.1:4174"
HOURLY_RETENTION_DAYS = "90"
DAILY_RETENTION_DAYS = "730"
EVENT_RETENTION_DAYS = "180"

# Configure secrets separately; never commit their values:
# wrangler secret put INGEST_TOKEN
# wrangler secret put MAINTENANCE_TOKEN
